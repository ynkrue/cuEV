# Doxyfile — cuEV

PROJECT_NAME           = "cuEV"
PROJECT_BRIEF          = "CUDA Symmetric Eigensolver"
PROJECT_NUMBER         = 0.1.0

OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
JAVADOC_AUTOBRIEF      = NO
MULTILINE_CPP_IS_BRIEF = NO

# Input
INPUT                  = include src README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.cu *.cuh *.cpp *.h *.md
EXTENSION_MAPPING      = cu=C++ cuh=C++
EXCLUDE_PATTERNS       = */build/*
USE_MDFILE_AS_MAINPAGE = README.md
STRIP_FROM_PATH        = .

# What to extract
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
INTERNAL_DOCS          = NO

# Output formats
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
HTML_OUTPUT            = html

# Doxygen Awesome theme
# https://github.com/jothepro/doxygen-awesome-css
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT
HTML_EXTRA_STYLESHEET  = doxygen/doxygen-awesome.css \
                         doxygen/doxygen-awesome-sidebar-only.css

# Preprocessing — strip CUDA qualifiers so Doxygen parses cleanly
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = "__global__=" \
                         "__device__=" \
                         "__host__=" \
                         "__shared__=" \
                         "__launch_bounds__(x)=" \
                         "__forceinline__=inline"
# Don't follow #include chains — parse each INPUT file independently so
# #pragma once in kernels.cuh doesn't cause its symbols to be silently dropped
SEARCH_INCLUDES        = NO

# Warnings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_LOGFILE           = docs/doxygen-warnings.log

# Misc
SORT_MEMBER_DOCS       = NO
SHOW_USED_FILES        = YES
SHOW_FILES             = YES
